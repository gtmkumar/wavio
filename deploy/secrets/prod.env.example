# Wavio production secrets template (issue #12).
#
# Copy this to prod.env, fill in real values, then run
# `deploy/secrets/encrypt.sh prod.env` to produce prod.env.enc — THAT file (not
# this one, not the plaintext prod.env) is what gets committed. See
# deploy/secrets/README.md for the full workflow.
#
# NEVER commit a plaintext prod.env — deploy/secrets/*.env is gitignored to
# make that mistake harder, but double-check `git status` before committing.

# --- Postgres -----------------------------------------------------------
# Superuser password (docker-compose.prod.yml's POSTGRES_PASSWORD). Only used
# for migrations (wavio.DbMigrator --connection-string) — no running service
# connects as this role.
POSTGRES_PASSWORD=

# app_user password — the RLS-enforced runtime role every service connects as.
# Consumed by deploy/postgres/init-prod/001-create-app-role.sh on first
# container init; must be created BEFORE migrations run so V001's
# `IF NOT EXISTS` bootstrap skips it (see that script's header comment).
POSTGRES_APP_PASSWORD=

# --- RabbitMQ -------------------------------------------------------------
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=

# --- Shared app secrets (every service that touches WavioDbContext) -------
# 32 random bytes, base64-encoded. Generate with:
#   openssl rand -base64 32
# Rotating this makes every enc:v1 PII value unreadable until re-saved — see
# wavio.AppHost/AppHost.cs's dev-key comment for the same caveat in prod.
PII_ENCRYPTION_KEY=

# --- Identity / JWT (core only) -------------------------------------------
# RS256 signing key ships as its own file, NOT a line here — see
# deploy/secrets/jwt-private-key.pem.example and deploy/secrets/README.md.
# This just points core at where the decrypted PEM will live on the VPS.
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private-key.pem

# --- Caddy / TLS -----------------------------------------------------------
# Public domain that resolves to the VPS — Caddy requests a Let's Encrypt cert
# for this via ACME HTTP-01 (needs port 80 reachable from the internet).
WAVIO_DOMAIN=

# --- GHCR image pull (deploy workflow / VPS docker compose pull) ----------
GHCR_OWNER=gtmkumar
IMAGE_TAG=latest
