{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "EnforceTokenVersion": true
  },
  "Jwt": {
    "Issuer": "wavio-identity",
    "Audience": "wavio-services",
    "AccessMinutes": 15,
    "RefreshDays": 30
  },
  "OAuthResource": {
    "McpBaseUrl": "https://localhost:7254",
    "IdentityBaseUrl": "https://localhost:7254"
  },
  "DownstreamServices": {
    "CatalogBaseUrl": "https://localhost:7254",
    "OrdersBaseUrl": "https://localhost:7254"
  }
}
