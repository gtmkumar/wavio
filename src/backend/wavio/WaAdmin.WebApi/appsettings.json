{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "EnforceTokenVersion": true
  },
  "Jwt": {
    "Issuer": "wavio-identity",
    "Audience": "wavio-services"
  },
  "Lint": {
    "Llm": {
      "Enabled": false
    }
  }
}
