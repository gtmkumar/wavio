{
  "name": "admin-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "api:generate": "for s in identity messaging admin billing intel; do openapi-typescript src/api/openapi/$s.json -o src/api/generated/$s.ts; done",
    "api:fetch": "for s in identity messaging admin billing intel; do curl -sf http://localhost:8080/$s/openapi/v1.json -o src/api/openapi/$s.json; done",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.71.0",
    "typescript": "~5.9.3",
    "vite": "^8.1.1"
  }
}
