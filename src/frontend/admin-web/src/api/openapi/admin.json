            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "captureChannel": {
            "type": "string"
          },
          "onBehalfOfWaId": {
            "type": [
              "null",
              "string"
            ]
          },
          "onBehalfOfName": {
            "type": [
              "null",
              "string"
            ]
          },
          "evidenceProofRef": {
            "type": [
              "null",
              "string"
            ]
          },
          "evidenceWamid": {
            "type": [
              "null",
              "string"
            ]
          },
          "actor": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "TemplateCategory": {
        "type": "integer"
      },
      "TemplateComponent": {
        "required": [
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "text": {
            "type": [
              "null",
              "string"
            ]
          },
          "extrasJson": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "TemplateDefinition": {
        "required": [
          "name",
          "language",
          "category",
          "components"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "category": {
            "$ref": "#/components/schemas/TemplateCategory"
          },
          "components": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TemplateComponent"
            }
          }
        }
      },
      "UpdateTemplateRequest": {
        "required": [
          "definition",
          "exampleValuesJson"
        ],
        "type": "object",
        "properties": {
          "definition": {
            "$ref": "#/components/schemas/TemplateDefinition"
          },
          "exampleValuesJson": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "UpsertRetentionPolicyRequest": {
        "required": [
          "dataClass",
          "retentionDays",
          "basis",
          "enabled"
        ],
        "type": "object",
        "properties": {
          "dataClass": {
            "type": "string"
          },
          "retentionDays": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "basis": {
            "type": [
              "null",
              "string"
            ]
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
